# ============================================================
# OPSI 2 — TARGET PROFIT (Mode Cari Cuan)
# Bot berhenti otomatis setelah profit bersih mencapai target,
# atau saat jackpot besar terkena (kunci langsung).
#
# Cara pakai:
#   cp config_profit.env .env
#   python3 main.py
# ============================================================

STAKE_API_TOKEN=           # ← isi token kamu

# Game
RISK=HIGH
ROWS=14                    # bisa diganti 16 untuk variasi
CURRENCY=IDR

# ── Bet acak per siklus ─────────────────────────────────────
# Setiap kali bet kembali ke dasar (menang / cut-loss), nominal
# dipilih secara acak antara MIN dan MAX — pola tidak terduga.
BET_AMOUNT_MIN=50          # bet paling kecil: Rp 50
BET_AMOUNT_MAX=100         # bet paling besar: Rp 100
# BET_AMOUNT=50            # aktifkan baris ini (dan nonaktifkan MIN/MAX) jika ingin tetap

# ── Strategi Martingale ─────────────────────────────────────
STRATEGY=MARTINGALE
BET_MULTIPLIER=2           # dobel setiap kalah: 50→100→200→400→800→1600→3200→6400→cap
MAX_BET=6400               # batas maksimal per bet (setelah 7 loss beruntun)
LOSS_STREAK_CAP=8          # setelah 8 kalah beruntun → cut-loss, reset ke base acak

# ── Timing — delay acak 1200–1800ms ────────────────────────
# Satu bola per giliran, tidak ada multi-ball.
# Interval acak membuat pola tidak mudah dideteksi server.
BASE_DELAY_MIN_MS=1200     # delay minimum per bet (ms)
BASE_DELAY_MAX_MS=1800     # delay maksimum per bet (ms)
# BASE_DELAY_MS=1500       # aktifkan jika ingin delay tetap

# ── Stop conditions ─────────────────────────────────────────
# Target profit bersih
TAKE_PROFIT=40000          # berhenti jika profit bersih >= +Rp 40.000
TAKE_PROFIT_DELAY_SEC=15   # countdown 15 detik (tekan Ctrl+C untuk lanjut)

# Jackpot lock — langsung berhenti tanpa countdown saat kena multiplier besar
JACKPOT_STOP_MULTIPLIER=420  # berhenti instan jika kena x420 atau lebih

# Batas rugi relatif — berhenti jika rugi >= Rp 30.000 dari modal awal sesi
MAX_LOSS=30000

# Stop loss absolut (saldo minimum) — atur sesuai modal kamu
STOP_LOSS=0                # 0 = nonaktif; contoh: 50000 = berhenti jika saldo <= Rp 50.000

WAGER_TARGET=0             # nonaktif untuk mode profit

# ── Safety ─────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# CATATAN RISIKO — MARTINGALE ROW 14 HIGH:
# - Row 14 HIGH: bola sering landing di slot tengah (multiplier < 1x)
#   → kalah beruntun SANGAT UMUM, Martingale eskalasi cepat
# - Eskalasi bet (dari Rp 50): 50→100→200→400→800→1600→3200→6400(cap)
# - Modal minimum untuk menahan 8 loss beruntun:
#   50+100+200+400+800+1600+3200+6400 = Rp 12.750
# - Pastikan saldo cukup sebelum mulai
# - MAX_LOSS=30000 melindungi modal: bot otomatis berhenti jika
#   rugi melebihi Rp 30.000 dari saldo awal sesi
# ============================================================
