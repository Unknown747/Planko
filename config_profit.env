# ============================================================
# OPSI 2 — TARGET PROFIT
# Bot berhenti otomatis setelah profit bersih mencapai TAKE_PROFIT.
# Cocok untuk: ambil untung harian lalu berhenti.
#
# Cara pakai:
#   cp config_profit.env .env
#   python3 main.py
# ============================================================

STAKE_API_TOKEN=           # ← isi token kamu

# Game
RISK=HIGH
ROWS=14
CURRENCY=IDR

# Strategi Martingale
STRATEGY=MARTINGALE
BET_AMOUNT=50              # bet awal 50 IDR
BET_MULTIPLIER=2           # dobel setiap kalah: 50→100→200→400→800→1600→3200→6400→cap
MAX_BET=6400               # batas maksimal per bet (setelah 7 loss beruntun)
LOSS_STREAK_CAP=8          # setelah 8 kalah beruntun → cut-loss, reset ke 50

# Stop condition: berhenti setelah profit bersih +25.000 IDR
TAKE_PROFIT=25000
TAKE_PROFIT_DELAY_SEC=30   # countdown 30 detik sebelum berhenti (bisa dibatalkan)
WAGER_TARGET=0             # nonaktif (tidak pakai target wager)

# Safety
STOP_LOSS=0                # nonaktif — atur sesuai modal kamu jika perlu
                           # contoh: STOP_LOSS=50000 (berhenti jika saldo <= 50rb)
BASE_DELAY_MS=150          # jeda antar bet (ms)
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# Log
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# CATATAN RISIKO MARTINGALE ROW 14 HIGH:
# - Row 14 HIGH: bola paling sering landing di slot tengah (multiplier < 1x)
#   artinya kalah beruntun SANGAT UMUM → Martingale eskalasi cepat
# - Eskalasi bet: 50→100→200→400→800→1600→3200→6400(cap)
# - Modal minimum aman untuk menahan 8 loss beruntun:
#   50+100+200+400+800+1600+3200+6400 = Rp 12.750
# - Pastikan saldo cukup sebelum mulai
# ============================================================
