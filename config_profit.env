# ============================================================
# MODE PROFIT — Cari Cuan (SAFE)
# Tujuan : mengumpulkan profit bersih sampai target, lalu stop
# Strategi: FLAT — bet Rp 50 tetap setiap putaran, tanpa recovery
#           (bet kecil = risiko kecil, tidak perlu dobel-dobelan)
# ============================================================

STAKE_API_TOKEN=           # ← isi token kamu (atau simpan di .env)

# ── Game ─────────────────────────────────────────────────────
RISK=HIGH
ROWS=14
CURRENCY=IDR

# ── Bet — FLAT, tidak ada recovery ───────────────────────────
# Bet selalu Rp 50 setiap putaran — sederhana, risiko terkontrol
STRATEGY=FLAT
BET_AMOUNT=50              # bet tetap Rp 50 per putaran

# ── Timing — delay acak 1200–1800ms ──────────────────────────
# Satu bola per giliran, interval tidak teratur agar tidak terdeteksi
BASE_DELAY_MIN_MS=1200
BASE_DELAY_MAX_MS=1800

# ── Target Profit ─────────────────────────────────────────────
TAKE_PROFIT=40000          # stop jika profit bersih >= +Rp 40.000
TAKE_PROFIT_DELAY_SEC=15   # countdown 15 detik (tekan Ctrl+C untuk lanjut)

# ── Proteksi Modal ────────────────────────────────────────────
MAX_LOSS=30000             # stop jika rugi >= Rp 30.000 dari modal awal sesi
JACKPOT_STOP_MULTIPLIER=420  # stop INSTAN (tanpa countdown) jika kena x420+

# ── Stop lainnya (nonaktif) ───────────────────────────────────
WAGER_TARGET=0
STOP_LOSS=0                # opsional: misal 50000 = stop jika saldo <= Rp 50.000

# ── Safety ───────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# KENAPA TIDAK PAKAI RECOVERY DI MODE PROFIT?
#   - Bet Rp 50 sangat kecil → kalah tidak terasa berat
#   - Recovery (Martingale) di bet kecil justru mempercepat
#     habisnya modal jika unlucky streak panjang
#   - FLAT + JACKPOT_STOP lebih efektif: tunggu x420 hit,
#     langsung kunci profit, selesai
#
# ESTIMASI:
#   Delay 1.2–1.8 detik → ~40–50 bet/menit
#   Target +Rp 40.000 dengan bet Rp 50 = butuh hit besar
#   Modal aman disarankan: Rp 50.000–100.000
# ============================================================
