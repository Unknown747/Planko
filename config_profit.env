# ============================================================
# MODE PROFIT — Cari Cuan (EXPERT)
# Tujuan   : dapat multiplier besar, kunci profit
# Strategi : FLAT — bet Rp 50–100 acak per putaran
# Pin      : dipilih saat startup (14 atau 16)
# ============================================================

STAKE_API_TOKEN=

# ── Game ─────────────────────────────────────────────────────
RISK=HIGH
ROWS=14               # default; akan ditimpa oleh pilihan menu (14/16)
CURRENCY=IDR

# ── Bet — acak Rp 50–100, 1 bola per giliran ─────────────────
STRATEGY=FLAT
BET_AMOUNT_MIN=50
BET_AMOUNT_MAX=100

# ── Timing — acak 1200–1800ms (1 bola per giliran) ───────────
BASE_DELAY_MIN_MS=1200
BASE_DELAY_MAX_MS=1800

# ── Stop Conditions ───────────────────────────────────────────
TAKE_PROFIT=0
TAKE_PROFIT_DELAY_SEC=15
MAX_LOSS=0
JACKPOT_STOP_MULTIPLIER=0
STOP_LOSS=50000        # stop jika saldo <= Rp 50.000 (sesuaikan modal)

# ── Safety ───────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ── Sesi, ringkasan, & refresh balance ───────────────────────
SESSION_RESET_BETS=0       # reset sesi setiap N bet (0 = nonaktif)
SESSION_RESET_MINUTES=0    # reset sesi setiap N menit (0 = nonaktif)
SUMMARY_EVERY_BETS=0       # ringkasan berkala setiap N bet (0 = nonaktif)
BALANCE_REFRESH_EVERY=10   # refresh balance dari API setiap N bet
