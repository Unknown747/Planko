# ============================================================
# OPSI 1 — TARGET WAGER (Mode Farming Bonus)
# Bot berhenti otomatis setelah total taruhan mencapai WAGER_TARGET.
# Cocok untuk: farming bonus wager / memenuhi syarat bonus Stake.
#
# Cara pakai:
#   python3 main.py wager
# ============================================================

STAKE_API_TOKEN=           # ← isi token kamu (atau simpan di .env)

# Game
RISK=HIGH
ROWS=14
CURRENCY=IDR

# ── Bet tetap ────────────────────────────────────────────────
# Mode wager pakai bet tetap — lebih cepat dan prediktif untuk farming
BET_AMOUNT=50              # bet per putaran: Rp 50
# BET_AMOUNT_MIN=50        # aktifkan ini jika mau bet acak (dan nonaktifkan BET_AMOUNT)
# BET_AMOUNT_MAX=100

# ── Strategi Martingale ──────────────────────────────────────
STRATEGY=MARTINGALE
BET_MULTIPLIER=2           # dobel setiap kalah: 50→100→200→400→800→1600→3200→6400→cap
MAX_BET=6400               # batas maksimal per bet
LOSS_STREAK_CAP=8          # setelah 8 kalah beruntun → cut-loss, reset ke 50

# ── Timing ───────────────────────────────────────────────────
BASE_DELAY_MS=150          # jeda tetap 150ms per bet (cepat untuk farming)
# BASE_DELAY_MIN_MS=1200   # aktifkan ini jika mau delay acak (dan nonaktifkan BASE_DELAY_MS)
# BASE_DELAY_MAX_MS=1800

# ── Stop conditions ──────────────────────────────────────────
WAGER_TARGET=500000        # berhenti setelah total taruhan Rp 500.000
TAKE_PROFIT=0              # nonaktif
TAKE_PROFIT_DELAY_SEC=30

# Perlindungan modal (opsional — aktifkan sesuai kebutuhan)
STOP_LOSS=0                # contoh: 50000 = berhenti jika saldo <= Rp 50.000
MAX_LOSS=0                 # contoh: 30000 = berhenti jika rugi >= Rp 30.000 dari awal sesi
JACKPOT_STOP_MULTIPLIER=0  # contoh: 420 = langsung berhenti jika kena x420+

# ── Safety ────────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# CATATAN RISIKO — MARTINGALE ROW 14 HIGH:
# - Row 14 HIGH: bola sering landing di slot tengah (multiplier < 1x)
#   → kalah beruntun SANGAT UMUM, Martingale eskalasi cepat
# - Eskalasi bet: 50→100→200→400→800→1600→3200→6400(cap)
# - Modal minimum untuk menahan 8 loss beruntun:
#   50+100+200+400+800+1600+3200+6400 = Rp 12.750
# - Pastikan saldo cukup sebelum mulai
# ============================================================
