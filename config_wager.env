# ============================================================
# MODE WAGER — Farming Bonus (SAFE)
# Tujuan : memenuhi target total taruhan (syarat bonus Stake)
# Strategi: Martingale ringan — bet 50, kalah naik ke 100, lalu
#           reset kembali ke 50 (recovery otomatis, risiko kecil)
# ============================================================

STAKE_API_TOKEN=           # ← isi token kamu (atau simpan di .env)

# ── Game ─────────────────────────────────────────────────────
RISK=HIGH
ROWS=14
CURRENCY=IDR

# ── Bet & Recovery ───────────────────────────────────────────
# Eskalasi: Rp 50  →  Rp 100 (cap)  →  reset ke Rp 50
# Maksimal rugi per siklus sebelum recovery: Rp 50 + Rp 100 = Rp 150
STRATEGY=MARTINGALE
BET_AMOUNT=500             # bet awal tiap siklus: Rp 500
BET_MULTIPLIER=2           # kalah → dobel: 500 → 1000
MAX_BET=1000               # batas maksimal bet (TIDAK akan melebihi ini)
LOSS_STREAK_CAP=0          # 0 = biarkan MAX_BET yang mengatur reset alami

# ── Target & Stop ─────────────────────────────────────────────
WAGER_TARGET=500000        # berhenti setelah total taruhan Rp 500.000 (~1.000 putaran)
TAKE_PROFIT=0              # nonaktif
TAKE_PROFIT_DELAY_SEC=30
STOP_LOSS=0                # opsional: misal 50000 = stop jika saldo <= Rp 50.000
MAX_LOSS=0                 # opsional: misal 30000 = stop jika rugi >= Rp 30.000
JACKPOT_STOP_MULTIPLIER=0  # opsional: misal 420 = stop instan jika kena x420

# ── Timing ───────────────────────────────────────────────────
BASE_DELAY_MS=200          # jeda 200ms per bet (cukup cepat, tidak spam)

# ── Safety ───────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# INFO RECOVERY:
#   Menang di Rp 500  → tetap Rp 500
#   Kalah  di Rp 500  → naik ke Rp 1.000  (recovery 1 level)
#   Menang di Rp 1.000 → reset ke Rp 500
#   Kalah  di Rp 1.000 → sudah di cap, reset ke Rp 500 otomatis
#
# Estimasi:
#   500.000 / 500 = ~1.000 putaran
#   Delay 200ms   = ~3–4 menit
#   Modal aman    = Rp 1.500 (worst case per siklus: 500 + 1000)
# ============================================================
