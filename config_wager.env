# ============================================================
# MODE WAGER — Farming Bonus (SAFE)
# Tujuan   : penuhi target total taruhan (syarat bonus Stake)
# Strategi : Martingale 2 level saja — bet 500, kalah naik ke
#            1000 (2x), kalah lagi reset ke 500. Tidak lebih.
# Risiko   : maks Rp 1.500 per siklus (500 + 1000)
# ============================================================

STAKE_API_TOKEN=

# ── Game ─────────────────────────────────────────────────────
RISK=HIGH
ROWS=14
CURRENCY=IDR

# ── Bet & Recovery (max 2 level recovery) ────────────────────
STRATEGY=MARTINGALE
BET_AMOUNT=500
BET_MULTIPLIER=2
MAX_BET=1000           # cap keras — tidak akan pernah > Rp 1.000
LOSS_STREAK_CAP=2      # reset ke base setelah 2x kalah berturut-turut (2 level)

# ── Stop ──────────────────────────────────────────────────────
STOP_LOSS=5000         # jaring pengaman: stop jika saldo <= Rp 5.000
TAKE_PROFIT=0
TAKE_PROFIT_DELAY_SEC=30
MAX_LOSS=0
JACKPOT_STOP_MULTIPLIER=0

# ── Timing ───────────────────────────────────────────────────
BASE_DELAY_MS=50

# ── Safety ───────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# ESKALASI BET (dengan LOSS_STREAK_CAP=2):
#   Menang di Rp 500   → tetap Rp 500
#   Kalah  di Rp 500   → naik Rp 1.000  (level 1 recovery, streak=1)
#   Menang di Rp 1.000 → reset ke Rp 500
#   Kalah  di Rp 1.000 → streak=2 ≥ CAP → reset ke Rp 500
#
# Biaya maks per siklus kalah semua: Rp 500 + Rp 1.000 = Rp 1.500
#
# ⚠️  Jangan ganti ke LOSS_STREAK_CAP=0 — kombinasi dengan MAX_BET=1000
#     akan membuat siklus 3 bet (500→1000→1000→reset = Rp 2.500/siklus)
#     bukan 2 bet seperti yang dimaksud.
# ============================================================
