# ============================================================
# MODE WAGER — Farming Bonus (SE-SAFE MUNGKIN)
# Tujuan    : penuhi target total taruhan (syarat bonus Stake)
#             sambil menjaga modal semaksimal mungkin
#
# Filosofi  :
#   RISK=LOW + ROWS=8 → distribusi payout paling sempit di Stake
#   Hampir semua bet kembali sekitar 0.5–2× — tidak ada ayunan
#   ekstrem seperti di HIGH/EXPERT. House edge tetap ada tapi
#   sangat kecil variansinya → drawdown lambat & terprediksi.
#
#   FLAT → setiap bet tetap Rp 500, tidak ada eskalasi sama sekali.
#   Tidak ada risiko siklus kalah beruntun yang menguras saldo.
#
# Tradeoff  : tidak ada recovery bet — kalah ya kalah Rp 500 saja.
#             Tapi total risiko per jam jauh lebih kecil dari
#             Martingale HIGH/14-pin yang lama.
# ============================================================

STAKE_API_TOKEN=

# ── Game — minimum variance ───────────────────────────────────
RISK=LOW           # payout paling stabil (bukan HIGH/EXPERT)
ROWS=8             # paling sedikit pin = paling kecil variance
CURRENCY=IDR

# ── Bet — flat, tidak ada eskalasi ───────────────────────────
STRATEGY=FLAT
BET_AMOUNT=500

# ── Timing — tidak terlalu cepat untuk hindari rate limit ────
BASE_DELAY_MS=200

# ── Stop Conditions ───────────────────────────────────────────
STOP_LOSS=20000        # stop jika saldo <= Rp 20.000
MAX_LOSS=100000        # stop jika rugi >= Rp 100.000 dari modal awal sesi
TAKE_PROFIT=0
TAKE_PROFIT_DELAY_SEC=30
JACKPOT_STOP_MULTIPLIER=0

# ── Safety ───────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ── Sesi, ringkasan, & refresh balance ───────────────────────
SESSION_RESET_BETS=0       # reset sesi setiap N bet (0 = nonaktif)
SESSION_RESET_MINUTES=0    # reset sesi setiap N menit (0 = nonaktif)
SUMMARY_EVERY_BETS=100     # ringkasan berkala setiap 100 bet
BALANCE_REFRESH_EVERY=5    # cek balance lebih sering (default 10) untuk stop-loss lebih responsif

# ============================================================
# PERBANDINGAN RISIKO vs KONFIGURASI LAMA:
#
# Lama (HIGH + 14 pin + Martingale):
#   Bet naik ke Rp 1.000 saat kalah pertama.
#   Kalah 2× berturut = rugi Rp 1.500 per siklus.
#   Dengan HIGH risk, streak kalah panjang lebih sering terjadi.
#
# Baru (LOW + 8 pin + FLAT):
#   Setiap bet selalu Rp 500 — tidak pernah lebih.
#   Payout sekitar 0.5–2×, jarang jauh dari 1×.
#   Rugi per jam jauh lebih kecil dan terprediksi.
# ============================================================
