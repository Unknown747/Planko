# ============================================================
# MODE WAGER — Farming Bonus (SAFE)
# Tujuan   : penuhi target total taruhan (syarat bonus Stake)
# Strategi : Martingale 2 level saja — bet 500, kalah naik ke
#            1000 (2x), kalah lagi reset ke 500. Tidak lebih.
# Risiko   : maks Rp 1.500 per siklus (500 + 1000)
# ============================================================

STAKE_API_TOKEN=

# ── Game ─────────────────────────────────────────────────────
RISK=HIGH
ROWS=14
CURRENCY=IDR

# ── Bet & Recovery (max multiplier 2x) ───────────────────────
STRATEGY=MARTINGALE
BET_AMOUNT=500
BET_MULTIPLIER=2
MAX_BET=1000           # cap keras — tidak akan pernah > Rp 1.000
LOSS_STREAK_CAP=0      # MAX_BET yang mengatur reset alami

# ── Target & Stop ─────────────────────────────────────────────
WAGER_TARGET=500000    # berhenti setelah total wager Rp 500.000
STOP_LOSS=5000         # jaring pengaman: stop jika saldo <= Rp 5.000
TAKE_PROFIT=0
TAKE_PROFIT_DELAY_SEC=30
MAX_LOSS=0
JACKPOT_STOP_MULTIPLIER=0

# ── Timing ───────────────────────────────────────────────────
BASE_DELAY_MS=200

# ── Safety ───────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=5
MAX_RATE_LIMIT_RETRIES=10

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=auto
LOG_MAX_LINES=1000

# ============================================================
# ESKALASI BET:
#   Menang di Rp 500   → tetap Rp 500
#   Kalah  di Rp 500   → naik Rp 1.000  (recovery 1 level)
#   Menang di Rp 1.000 → reset ke Rp 500
#   Kalah  di Rp 1.000 → sudah di cap MAX_BET, reset ke Rp 500
#
# Total wager 500.000 dengan bet rata-rata ~600:
#   estimasi ~833 putaran, delay 200ms ≈ 3–4 menit
# ============================================================
