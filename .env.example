# ============================================================
# Salin file ini ke .env lalu isi nilainya:
#   cp .env.example .env
# ============================================================

# [WAJIB] Token API dari Stake.com
# Cara dapat: buka Stake.com → login → F12 → tab Network
# → klik request apa saja ke _api/graphql → lihat Request Headers
# → salin nilai x-access-token
STAKE_API_TOKEN=

# [OPSIONAL] Pengaturan game (ada default jika tidak diisi)
RISK=LOW          # LOW | MEDIUM | HIGH
ROWS=8            # 8 | 9 | 10 | 11 | 12 | 13 | 14 | 15 | 16
BET_AMOUNT=500    # nominal bet per round (dalam currency yang dipilih)
CURRENCY=IDR      # IDR | BTC | ETH | USDT | dll

# [OPSIONAL] Strategi betting
# FLAT          = bet selalu tetap (default, aman)
# ANTI_MARTINGALE = naik saat menang, reset saat kalah (aman untuk modal kecil)
STRATEGY=ANTI_MARTINGALE
BET_MULTIPLIER=2            # pengali bet saat menang (contoh: 2 = lipat dua)
WIN_STREAK_CAP=3            # maks berapa kali lipat berturut-turut sebelum reset
                            # contoh cap=3, bet=500: 500→1000→2000→reset ke 500
MAX_BET=0                   # batas atas nominal bet (0 = tidak dibatas)

# [OPSIONAL] Kontrol bot
BASE_DELAY_MS=200           # jeda antar bet (ms), minimum 100 disarankan
STOP_LOSS=10000             # berhenti jika saldo <= nilai ini (0 = nonaktif)
TAKE_PROFIT=10000           # berhenti jika profit bersih >= nilai ini (0 = nonaktif)
TAKE_PROFIT_DELAY_SEC=30    # countdown sebelum berhenti saat take profit (detik)
WAGER_TARGET=0              # berhenti setelah total wager ini (0 = tidak ada batas)
MAX_CONSECUTIVE_ERRORS=5    # berhenti setelah N error berturut-turut
MAX_RATE_LIMIT_RETRIES=10   # maks retry saat kena rate limit (429)

# [OPSIONAL] Log file
# auto        = buat file otomatis: plinko_YYYYMMDD_HHMMSS.csv (default)
# NONE        = nonaktifkan logging
# custom.csv  = nama file kustom
LOG_FILE=auto
LOG_MAX_LINES=1000          # maks baris data disimpan; lebih lama otomatis dipangkas
