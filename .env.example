# ============================================================
# File ini adalah REFERENSI semua variabel yang tersedia.
#
# Cara pakai normal (direkomendasikan):
#   1. bash setup.sh          → buat .env berisi token saja
#   2. python3 main.py        → pilih mode lewat menu (profit/wager)
#      Setting game diambil dari config_profit.env atau config_wager.env
#
# Cara pakai manual (advanced):
#   cp .env.example .env      → lalu edit .env, jalankan tanpa argumen mode
#
# ⚠️  PERHATIAN: Jika kamu mengisi RISK, ROWS, BET_AMOUNT, dll di .env,
#     nilai itu akan OVERRIDE preset config_profit.env / config_wager.env
#     karena .env punya prioritas lebih tinggi.
#     Kosongkan / hapus baris itu di .env jika ingin pakai preset.
# ============================================================

# [WAJIB] Token API dari Stake.com
# Cara dapat: buka Stake.com → login → F12 → tab Network
# → klik request apa saja ke _api/graphql → lihat Request Headers
# → salin nilai x-access-token
STAKE_API_TOKEN=

# [OPSIONAL] Pengaturan game — default jika tidak diisi
# ⚠️  Nilai di sini OVERRIDE preset config_profit/wager.env jika diisi
RISK=LOW          # LOW | MEDIUM | HIGH
ROWS=8            # 8 | 9 | 10 | 11 | 12 | 13 | 14 | 15 | 16
BET_AMOUNT=500    # nominal bet tetap per round (diabaikan jika BET_AMOUNT_MIN/MAX diisi)
CURRENCY=IDR      # IDR | BTC | ETH | USDT | dll

# [OPSIONAL] Bet acak per siklus reset
# Jika diisi, base bet dirandom antara MIN dan MAX setiap reset (lebih tidak terduga)
# Kosongkan / set 0 jika ingin BET_AMOUNT tetap
BET_AMOUNT_MIN=0            # batas bawah bet acak (Rp), 0 = nonaktif
BET_AMOUNT_MAX=0            # batas atas bet acak (Rp), 0 = nonaktif

# [OPSIONAL] Strategi betting
# FLAT            = bet selalu tetap (default, aman)
# ANTI_MARTINGALE = naik saat menang, reset saat kalah
# MARTINGALE      = dobel saat kalah, reset saat menang (agresif, butuh modal)
STRATEGY=FLAT
BET_MULTIPLIER=2            # pengali bet (saat menang untuk Anti-M, saat kalah untuk Martingale)
WIN_STREAK_CAP=3            # [ANTI_MARTINGALE] maks lipat beruntun sebelum reset
LOSS_STREAK_CAP=0           # [MARTINGALE] maks kalah beruntun sebelum cut-loss (0 = tidak dibatas)
MAX_BET=0                   # batas atas nominal bet per putaran (0 = tidak dibatas)

# [OPSIONAL] Kontrol bot & timing
BASE_DELAY_MS=200           # jeda tetap antar bet (ms) — diabaikan jika MIN/MAX diisi
BASE_DELAY_MIN_MS=0         # batas bawah delay acak (ms), 0 = nonaktif
BASE_DELAY_MAX_MS=0         # batas atas delay acak (ms), 0 = nonaktif

# [OPSIONAL] Stop conditions
STOP_LOSS=10000             # berhenti jika SALDO ABSOLUT <= nilai ini (0 = nonaktif)
MAX_LOSS=0                  # berhenti jika RUGI RELATIF >= nilai ini dari modal awal (0 = nonaktif)
TAKE_PROFIT=0               # berhenti jika profit bersih >= nilai ini (0 = nonaktif)
TAKE_PROFIT_DELAY_SEC=30    # countdown sebelum berhenti saat take profit (detik)
JACKPOT_STOP_MULTIPLIER=0   # berhenti LANGSUNG (tanpa countdown) jika kena multiplier ini (0 = nonaktif)
MAX_CONSECUTIVE_ERRORS=5    # berhenti setelah N error berturut-turut
MAX_RATE_LIMIT_RETRIES=10   # maks retry saat kena rate limit (429)

# [OPSIONAL] Log file
# auto        = buat file otomatis: plinko_YYYYMMDD_HHMMSS.csv (default)
# NONE        = nonaktifkan logging
# custom.csv  = nama file kustom
LOG_FILE=auto
LOG_MAX_LINES=1000          # maks baris data disimpan; lebih lama otomatis dipangkas
